# Supabase（必填）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 鉴权（smoke / auth/token 需要）
AUTH_TOKEN_SECRET=your-hs256-secret-at-least-32-chars
AUTH_CLIENT_ID=cmp
AUTH_CLIENT_SECRET=cmp-secret

# 管理端（可选，用于 admin 接口与完整 smoke）
ADMIN_API_KEY=your-admin-key

# Smoke 扩展测试（可选，未设置则跳过相关用例）
# SMOKE_SIM_ICCID=8986...
# SMOKE_RESELLER_ADMIN_TOKEN=eyJ...
# SMOKE_SIM_MSISDN=...

# 可选
PORT=3000
